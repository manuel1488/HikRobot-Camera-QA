<Window x:Class="TRVisionAI.Desktop.Views.HomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TR Vision AI" Height="520" Width="680"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        Icon="../Assets/app.ico"
        Background="#1A1A1A">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>     <!-- Logo + título -->
            <RowDefinition Height="Auto"/>  <!-- Botones -->
            <RowDefinition Height="40"/>    <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ── Logo + título ──────────────────────────────────── -->
        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">

            <Image Source="/Assets/logo-white.png"
                   Width="260" Margin="0,0,0,24"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <TextBlock Text="Sistema de Inspección Visual"
                       Foreground="#CCCCCC" FontSize="15"
                       HorizontalAlignment="Center" Margin="0,0,0,4"/>

            <TextBlock Text="MV-SC3050M"
                       Foreground="#666" FontSize="12"
                       HorizontalAlignment="Center" Margin="0,0,0,6"/>

            <TextBlock x:Name="TxtVersion"
                       Foreground="#444" FontSize="11"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- ── Botones ────────────────────────────────────────── -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,40">

            <Button x:Name="BtnStart"
                    Width="300" Height="52" Margin="0,0,0,14"
                    Cursor="Hand" Click="BtnStart_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#0078D4" CornerRadius="4">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="▶" Foreground="White" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="Iniciar Inspección" Foreground="White" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#106EBE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button x:Name="BtnSettings"
                    Width="300" Height="52"
                    Cursor="Hand" Click="BtnSettings_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#2D2D2D" CornerRadius="4"
                                BorderBrush="#444" BorderThickness="1">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="⚙" Foreground="#AAAAAA" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="Configuración" Foreground="#CCCCCC" FontSize="15" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>

        <!-- ── Footer ─────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="#111">
            <DockPanel Margin="16,0">
                <TextBlock x:Name="TxtFooterVersion" DockPanel.Dock="Right"
                           Foreground="#333" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Text="Two Rockets Software Solutions"
                           Foreground="#444" FontSize="11"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
