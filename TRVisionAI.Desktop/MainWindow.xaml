<Window x:Class="TRVisionAI.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TR Vision AI — Inspección Visual" Height="700" Width="1100"
        MinWidth="900" MinHeight="600"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Icon="Assets/app.ico"
        Background="#1E1E1E">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="OkRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <DataTrigger Binding="{Binding VerdictText}" Value="OK">
                    <Setter Property="Background" Value="#1A3A2A"/>
                    <Setter Property="Foreground" Value="#7FBA00"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding VerdictText}" Value="NG">
                    <Setter Property="Background" Value="#3A1A1A"/>
                    <Setter Property="Foreground" Value="#E05050"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="ToolbarBtn">
            <Setter Property="Background"      Value="#0078D4"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="16,6"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Margin"          Value="4,0"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#3A3A3A"/>
                    <Setter Property="Foreground" Value="#666"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="*"/>     <!-- Contenido -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- TOOLBAR                                                 -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#252526" Padding="10,8">
            <DockPanel>
                <!-- ← Inicio -->
                <Button DockPanel.Dock="Left" Content="← Inicio"
                        Style="{StaticResource ToolbarBtn}"
                        Background="#2D2D2D"
                        Click="BtnHome_Click"
                        Margin="0,0,8,0"/>

                <Separator DockPanel.Dock="Left" Background="#444" Width="1" Margin="0,4,8,4"/>

                <!-- Detener -->
                <Button DockPanel.Dock="Left"
                        Content="■  Detener"
                        Command="{Binding DisconnectCommand}"
                        Style="{StaticResource ToolbarBtn}"
                        Background="#A04040"/>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- CONTENIDO PRINCIPAL                                     -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="460"/>
            </Grid.ColumnDefinitions>

            <!-- Imagen en vivo -->
            <Border Grid.Column="0" Background="Black" Margin="4">
                <Grid>
                    <Image x:Name="LiveImageControl"
                           Source="{Binding LiveImage}" Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="Sin imagen" Foreground="#333"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="16">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LiveImage}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <!-- Overlay de inspección en vivo -->
                    <Canvas x:Name="LiveOverlayCanvas" IsHitTestVisible="False"/>
                </Grid>
            </Border>

            <!-- Panel derecho -->
            <Grid Grid.Column="1" Margin="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Contadores OK / NG / TOTAL -->
                <Border Grid.Row="0" Background="#252526" Padding="12,10" Margin="0,0,0,4">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <StackPanel Margin="0,0,28,0">
                            <TextBlock Text="OK" Foreground="#7FBA00" FontSize="12" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding OkCount}" Foreground="#7FBA00"
                                       FontSize="36" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,28,0">
                            <TextBlock Text="NG" Foreground="#E05050" FontSize="12" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding NgCount}" Foreground="#E05050"
                                       FontSize="36" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="TOTAL" Foreground="#AAAAAA" FontSize="12" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalCount}" Foreground="White"
                                       FontSize="36" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Tabla de resultados (doble-click para ver detalle) -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Results}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserSortColumns="False"
                          Background="#1E1E1E" Foreground="White"
                          BorderThickness="0"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#2A2A2A"
                          RowStyle="{StaticResource OkRowStyle}"
                          MouseDoubleClick="ResultsGrid_DoubleClick">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background"       Value="#252526"/>
                            <Setter Property="Foreground"       Value="#888"/>
                            <Setter Property="Padding"          Value="6,5"/>
                            <Setter Property="BorderThickness"  Value="0,0,0,1"/>
                            <Setter Property="BorderBrush"      Value="#333"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#"         Binding="{Binding RowNum}"                             Width="40"/>
                        <DataGridTextColumn Header="Hora"      Binding="{Binding ReceivedAt, StringFormat=HH:mm:ss.fff}" Width="88"/>
                        <DataGridTextColumn Header="Resultado" Binding="{Binding VerdictText}"                         Width="70"/>
                        <DataGridTextColumn Header="Solución"  Binding="{Binding SolutionName}"                        Width="*"/>
                        <DataGridTextColumn Header="Total"     Binding="{Binding TotalCount}"                          Width="50"/>
                        <DataGridTextColumn Header="NG"        Binding="{Binding NgCount}"                             Width="42"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- STATUS BAR                                              -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#1A1A1A" BorderBrush="#333"
                BorderThickness="0,1,0,0" Padding="10,5">
            <DockPanel>

                <!-- Derecha: versión + marca -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <TextBlock Text="Two Rockets" Foreground="#444" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding AppVersion}" Foreground="#444" FontSize="11"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Izquierda: indicador de estado + campos de sesión -->
                <StackPanel Orientation="Horizontal">

                    <!-- Indicador conectado/desconectado -->
                    <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#555"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="#7FBA00"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>

                    <!-- Mensaje de estado -->
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="#CCCCCC" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,16,0"/>

                    <!-- Separador + datos de sesión (solo cuando conectado) -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}">

                        <TextBlock Text="|" Foreground="#444" Margin="0,0,16,0" VerticalAlignment="Center"/>

                        <TextBlock Text="IP" Foreground="#555" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding CameraIp}" Foreground="#AAAAAA" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,16,0"/>

                        <TextBlock Text="Modelo" Foreground="#555" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding CameraModel}" Foreground="#AAAAAA" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,16,0"/>

                        <TextBlock Text="Usuario" Foreground="#555" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding SessionUser}" Foreground="#AAAAAA" FontSize="11"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
