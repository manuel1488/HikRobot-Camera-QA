<Window x:Class="TRVisionAI.Desktop.Views.FrameDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalle de inspección"
        Width="1200" Height="760"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterOwner"
        WindowState="Maximized"
        ResizeMode="CanResizeWithGrip"
        Background="#1E1E1E"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style x:Key="ModuleRowStyle" TargetType="ListBoxItem">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="*"/>     <!-- Contenido -->
            <RowDefinition Height="Auto"/>  <!-- Botón cerrar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════ HEADER (disponible de inmediato) ═══════════════════ -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Veredicto + info -->
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Border x:Name="VerdictBadge" CornerRadius="4" Padding="10,4" Margin="0,0,12,0" VerticalAlignment="Center">
                    <TextBlock x:Name="VerdictLabel" FontSize="18" FontWeight="Bold"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="SolutionLabel"  Foreground="#AAAAAA" FontSize="13"/>
                    <TextBlock x:Name="TimestampLabel" Foreground="#666666" FontSize="11"/>
                </StackPanel>
            </StackPanel>

            <!-- Navegación prev / next -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="BtnPrev" Content="◀" Width="32" Height="32"
                        Background="#2D2D2D" Foreground="White" BorderBrush="#444" BorderThickness="1"
                        Cursor="Hand" FontSize="13" Click="BtnPrev_Click"
                        ToolTip="Frame anterior  (←)"/>
                <TextBlock x:Name="NavLabel" Foreground="#AAAAAA" FontSize="12"
                           VerticalAlignment="Center" Margin="8,0" MinWidth="60"
                           TextAlignment="Center"/>
                <Button x:Name="BtnNext" Content="▶" Width="32" Height="32"
                        Background="#2D2D2D" Foreground="White" BorderBrush="#444" BorderThickness="1"
                        Cursor="Hand" FontSize="13" Click="BtnNext_Click"
                        ToolTip="Frame siguiente  (→)"/>
            </StackPanel>
        </Grid>

        <!-- ═══════════════════ CONTENIDO ═══════════════════ -->
        <Grid Grid.Row="1">

            <!-- Spinner de carga -->
            <StackPanel x:Name="LoadingOverlay" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="Collapsed">
                <TextBlock Text="Cargando detalle…" Foreground="#AAAAAA"
                           FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                             Background="#333" Foreground="#0078D4" BorderThickness="0"/>
            </StackPanel>

            <!-- Error -->
            <TextBlock x:Name="ErrorText" Foreground="#E05050" FontSize="13"
                       VerticalAlignment="Center" HorizontalAlignment="Center"
                       Visibility="Collapsed"/>

            <!-- Contenido real (oculto hasta que carga) -->
            <Grid x:Name="ContentPanel" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="320" MinWidth="260"/>
                </Grid.ColumnDefinitions>

                <!-- Imagen principal -->
                <Border Grid.Column="0" Background="Black" CornerRadius="4" Margin="0,0,8,0">
                    <Grid>
                        <Image x:Name="FrameImage" Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"/>

                        <!-- Máscara de fallo superpuesta -->
                        <Image x:Name="MaskImage" Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Opacity="0.55" Visibility="Collapsed"/>

                        <TextBlock Text="Sin imagen" Foreground="#333"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Source={x:Reference FrameImage}, Path=Source}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Overlay de resultados (texto verde + punto central) -->
                        <Canvas x:Name="OverlayCanvas" IsHitTestVisible="False"/>

                        <!-- Botón para alternar la máscara -->
                        <ToggleButton x:Name="MaskToggle"
                                      Content="Máscara"
                                      HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                      Margin="0,0,8,8" Padding="8,3"
                                      FontSize="11" Cursor="Hand"
                                      Background="#CC000000" Foreground="#AAAAAA"
                                      BorderBrush="#444" BorderThickness="1"
                                      Checked="MaskToggle_Checked"
                                      Unchecked="MaskToggle_Unchecked"
                                      Visibility="Collapsed"/>
                    </Grid>
                </Border>

                <!-- Panel derecho: módulos + JSON -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Módulos -->
                    <TextBlock Grid.Row="0" Text="MÓDULOS" Foreground="#666" FontSize="10"
                               Margin="0,0,0,4" FontWeight="Bold"/>

                    <Border Grid.Row="1" Background="#252526" CornerRadius="4" Padding="6" Margin="0,0,0,8"
                            MaxHeight="280">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ListBox x:Name="ModulesList" Background="Transparent" BorderThickness="0"
                                 ItemContainerStyle="{StaticResource ModuleRowStyle}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,2" Padding="6,4" CornerRadius="3"
                                            Background="{Binding Background}">
                                        <StackPanel>
                                            <DockPanel>
                                                <TextBlock DockPanel.Dock="Right" Text="{Binding VerdictText}"
                                                           FontWeight="Bold" FontSize="11"
                                                           Foreground="{Binding ForegroundColor}"/>
                                                <TextBlock Text="{Binding ModuleName}"
                                                           Foreground="#CCCCCC" FontSize="12"/>
                                            </DockPanel>
                                            <!-- Línea de detalle solo para módulos NG con información extra -->
                                            <TextBlock Text="{Binding DetailLine}"
                                                       Foreground="#CC8888" FontSize="10"
                                                       Margin="0,1,0,0" FontStyle="Italic">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasDetail}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        </ScrollViewer>
                    </Border>

                    <!-- JSON crudo -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="JSON RESULTADO" Foreground="#666" FontSize="10"
                                   Margin="0,0,0,4" FontWeight="Bold"/>
                        <Border Grid.Row="1" Background="#0D0D0D" CornerRadius="4">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                <TextBox x:Name="RawJsonBox"
                                         IsReadOnly="True" Background="Transparent"
                                         Foreground="#88C0A8" BorderThickness="0"
                                         FontFamily="Consolas" FontSize="11"
                                         Padding="8" TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <!-- ═══════════════════ BOTÓN CERRAR ═══════════════════ -->
        <Button Grid.Row="2" Content="Cerrar"
                HorizontalAlignment="Right" Margin="0,10,0,0"
                Padding="20,6" Click="BtnClose_Click"
                Background="#0078D4" Foreground="White" BorderThickness="0" Cursor="Hand"/>
    </Grid>
</Window>
