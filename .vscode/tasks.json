{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build TRVisionAI.Probe",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/TRVisionAI.Probe/TRVisionAI.Probe.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary",
        "--configuration", "Debug"
      ],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "build TRVisionAI.Desktop",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/TRVisionAI.Desktop/TRVisionAI.Desktop.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary",
        "--configuration", "Debug"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build solution",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/TRVisionAI.sln",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary",
        "--configuration", "Debug"
      ],
      "problemMatcher": "$msCompile"
    }
  ]
}
