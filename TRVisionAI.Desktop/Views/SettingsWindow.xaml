<Window x:Class="TRVisionAI.Desktop.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TR Vision AI — Configuración" Height="500" Width="480"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="#1E1E1E">

    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="Label">
            <Setter Property="Foreground"       Value="#AAAAAA"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"           Value="0,0,8,0"/>
            <Setter Property="Width"            Value="110"/>
        </Style>
        <Style TargetType="TextBox" x:Key="Input">
            <Setter Property="Background"  Value="#2D2D2D"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Padding"     Value="6,4"/>
        </Style>
        <Style TargetType="PasswordBox" x:Key="PwdInput">
            <Setter Property="Background"  Value="#2D2D2D"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Padding"     Value="6,4"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="SectionHeader">
            <Setter Property="Foreground" Value="#569CD6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Margin"     Value="0,0,0,8"/>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Cámara -->
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>  <!-- API -->
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>  <!-- Botones -->
        </Grid.RowDefinitions>

        <!-- ── Cámara ─────────────────────────────────────────── -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Cámara" Style="{StaticResource SectionHeader}"/>

            <!-- Detección automática -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Detectar" Style="{StaticResource Label}"/>

                <!-- ComboBox con cámaras encontradas (visible solo si hay resultados) -->
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding FoundCameras}"
                          SelectedItem="{Binding SelectedFoundCamera}"
                          Visibility="{Binding HasCameras, Converter={StaticResource BoolToVis}}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <Run Text="{Binding IpAddress, Mode=OneWay}"/>
                                <Run Text="  "/>
                                <Run Text="{Binding ModelName, Mode=OneWay}"/>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Button Grid.Column="2"
                        Command="{Binding ScanCamerasCommand}"
                        Background="#2D2D2D" Foreground="White" BorderBrush="#555" BorderThickness="1"
                        Padding="10,4" Margin="6,0,0,0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Content" Value="Buscar"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsScanning}" Value="True">
                                    <Setter Property="Content" Value="…"/>
                                    <Setter Property="IsEnabled" Value="False"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Campos manuales -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="32"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="IP / Host"  Style="{StaticResource Label}"/>
                <TextBox   Grid.Row="0" Grid.Column="1" Style="{StaticResource Input}"
                           Text="{Binding CameraIp, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Usuario"    Style="{StaticResource Label}"/>
                <TextBox   Grid.Row="1" Grid.Column="1" Style="{StaticResource Input}"
                           Text="{Binding CameraUser, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Contraseña" Style="{StaticResource Label}"/>
                <PasswordBox Grid.Row="2" Grid.Column="1" Style="{StaticResource PwdInput}"
                             x:Name="CameraPwd" PasswordChanged="CameraPwd_Changed"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Modo MD5"   Style="{StaticResource Label}"/>
                <CheckBox  Grid.Row="3" Grid.Column="1"
                           IsChecked="{Binding UseEncryption}"
                           Foreground="#AAAAAA" VerticalAlignment="Center"
                           Content="Cifrar contraseña con MD5 antes de enviar"/>
            </Grid>
        </StackPanel>

        <!-- ── API REST ───────────────────────────────────────── -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="API REST" Style="{StaticResource SectionHeader}"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="32"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Base URL" Style="{StaticResource Label}"/>
                <TextBox   Grid.Row="0" Grid.Column="1" Style="{StaticResource Input}"
                           Text="{Binding ApiBaseUrl, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="API Key"  Style="{StaticResource Label}"/>
                <PasswordBox Grid.Row="1" Grid.Column="1" Style="{StaticResource PwdInput}"
                             x:Name="ApiKeyPwd" PasswordChanged="ApiKey_Changed"/>
            </Grid>
        </StackPanel>

        <!-- ── Botones ────────────────────────────────────────── -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
                       Foreground="#7FBA00" VerticalAlignment="Center"
                       TextWrapping="Wrap"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Cancelar" Command="{Binding CancelCommand}"
                        Background="#444" Foreground="White" BorderThickness="0"
                        Padding="14,6" Margin="0,0,8,0" Cursor="Hand"/>
                <Button Content="Guardar" Command="{Binding SaveCommand}"
                        Background="#0078D4" Foreground="White" BorderThickness="0"
                        Padding="14,6" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
