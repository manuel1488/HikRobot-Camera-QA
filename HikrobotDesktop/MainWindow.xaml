<Window x:Class="HikrobotDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HikrobotDesktop.ViewModels"
        xmlns:models="clr-namespace:Hikrobot.Models;assembly=HikrobotCamera"
        Title="Hikrobot — MV-SC3050M" Height="700" Width="1100"
        Background="#1E1E1E">

    <Window.Resources>
        <!-- Conversor de veredicto a color de fondo de fila -->
        <Style x:Key="OkRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <DataTrigger Binding="{Binding VerdictText}" Value="OK">
                    <Setter Property="Background" Value="#1A3A2A"/>
                    <Setter Property="Foreground" Value="#7FBA00"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding VerdictText}" Value="NG">
                    <Setter Property="Background" Value="#3A1A1A"/>
                    <Setter Property="Foreground" Value="#E05050"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>

        <Style TargetType="TextBox" x:Key="InputStyle">
            <Setter Property="Background"  Value="#2D2D2D"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Padding"     Value="4,2"/>
            <Setter Property="MinWidth"    Value="100"/>
        </Style>

        <Style TargetType="ComboBox" x:Key="ComboStyle">
            <Setter Property="Background"  Value="#2D2D2D"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="MinWidth"    Value="220"/>
        </Style>

        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Background"       Value="#0078D4"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Padding"          Value="14,6"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Margin"           Value="4,0"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#444"/>
                    <Setter Property="Foreground" Value="#888"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Toolbar de conexión -->
            <RowDefinition Height="*"/>     <!-- Contenido principal -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- TOOLBAR DE CONEXIÓN                                     -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#252526" Padding="10,8">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">

                <!-- Cámara -->
                <TextBlock Text="Cámara:" Style="{StaticResource LabelStyle}"/>
                <ComboBox ItemsSource="{Binding Cameras}"
                          SelectedItem="{Binding SelectedCamera}"
                          DisplayMemberPath="IpAddress"
                          Style="{StaticResource ComboStyle}"
                          IsEnabled="{Binding IsDisconnected}"
                          Margin="0,0,8,0"/>

                <Button Content="Buscar" Command="{Binding ScanCommand}"
                        Style="{StaticResource ActionButton}"
                        IsEnabled="{Binding IsDisconnected}"/>

                <Separator Background="#444" Width="1" Margin="8,0"/>

                <!-- Usuario -->
                <TextBlock Text="Usuario:" Style="{StaticResource LabelStyle}"/>
                <TextBox Text="{Binding User, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource InputStyle}"
                         IsEnabled="{Binding IsDisconnected}"
                         Margin="0,0,8,0"/>

                <!-- Contraseña -->
                <TextBlock Text="Contraseña:" Style="{StaticResource LabelStyle}"/>
                <PasswordBox x:Name="PwdBox"
                             Background="#2D2D2D" Foreground="White"
                             BorderBrush="#555" Padding="4,2" MinWidth="100"
                             IsEnabled="{Binding IsDisconnected}"
                             Margin="0,0,8,0"
                             PasswordChanged="PwdBox_PasswordChanged"/>

                <!-- MD5 -->
                <CheckBox Content="MD5"
                          IsChecked="{Binding UseEncryption}"
                          Foreground="#AAAAAA" VerticalAlignment="Center"
                          IsEnabled="{Binding IsDisconnected}"
                          Margin="0,0,12,0"/>

                <!-- Botones -->
                <Button Content="Conectar"
                        Command="{Binding ConnectCommand}"
                        Style="{StaticResource ActionButton}"/>

                <Button Content="Desconectar"
                        Command="{Binding DisconnectCommand}"
                        Style="{StaticResource ActionButton}"
                        Background="#A04040"/>
            </WrapPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- CONTENIDO PRINCIPAL                                     -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>        <!-- Imagen -->
                <ColumnDefinition Width="480"/>      <!-- Panel derecho -->
            </Grid.ColumnDefinitions>

            <!-- Imagen en vivo -->
            <Border Grid.Column="0" Background="Black" Margin="4">
                <Grid>
                    <Image Source="{Binding LiveImage}" Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="Sin imagen" Foreground="#555"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="16">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LiveImage}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- Panel derecho: contadores + tabla -->
            <Grid Grid.Column="1" Margin="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Contadores -->
                    <RowDefinition Height="*"/>     <!-- Tabla -->
                </Grid.RowDefinitions>

                <!-- Contadores -->
                <Border Grid.Row="0" Background="#252526" Padding="12,8" Margin="0,0,0,4">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <StackPanel Margin="0,0,24,0">
                            <TextBlock Text="OK" Foreground="#7FBA00" FontSize="12" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding OkCount}" Foreground="#7FBA00"
                                       FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,24,0">
                            <TextBlock Text="NG" Foreground="#E05050" FontSize="12" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding NgCount}" Foreground="#E05050"
                                       FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="TOTAL" Foreground="#AAAAAA" FontSize="12" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalCount}" Foreground="White"
                                       FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Tabla de resultados -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Results}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserSortColumns="False"
                          Background="#1E1E1E"
                          Foreground="White"
                          BorderThickness="0"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#333"
                          RowStyle="{StaticResource OkRowStyle}">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#252526"/>
                            <Setter Property="Foreground" Value="#AAAAAA"/>
                            <Setter Property="Padding"    Value="6,4"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#444"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#"        Binding="{Binding RowNum}"                    Width="40"/>
                        <DataGridTextColumn Header="Hora"     Binding="{Binding ReceivedAt, StringFormat=HH:mm:ss.fff}" Width="90"/>
                        <DataGridTextColumn Header="Resultado" Binding="{Binding VerdictText}"              Width="70"/>
                        <DataGridTextColumn Header="Solución" Binding="{Binding SolutionName}"              Width="*"/>
                        <DataGridTextColumn Header="Total"    Binding="{Binding TotalCount}"                Width="55"/>
                        <DataGridTextColumn Header="NG"       Binding="{Binding NgCount}"                   Width="45"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- STATUS BAR                                              -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#007ACC" Padding="10,4">
            <TextBlock Text="{Binding StatusMessage}" Foreground="White" FontSize="12"/>
        </Border>
    </Grid>
</Window>
